---
import Layout from "../layouts/Layout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import SimplexSolver from "../components/SimplexSolver.tsx";
---

<Layout>
  <main class="mx-auto w-full max-w-5xl px-5 py-12 sm:py-16">
    <div class="mb-10 flex items-start justify-between gap-4">
      <header>
        <p
          class="mb-3 inline-block border-b border-neutral-300 pb-1 text-xs font-medium uppercase tracking-[0.2em] text-neutral-500 dark:border-neutral-700 dark:text-neutral-400"
        >
          Linear Programming · Two-Phase Method
        </p>
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Simplex Solver</h1>
        <p class="mt-4 max-w-2xl text-balance text-neutral-600 dark:text-neutral-400">
          Build a linear program, hit solve, and step through every Simplex pivot.
          Handles maximisation and minimisation with ≤, ≥ and = constraints,
          artificial variables and Phase 1 are added automatically when needed.
        </p>
      </header>
      <ThemeToggle />
    </div>

    <SimplexSolver client:load />

    <footer
      class="mt-16 border-t border-neutral-200 pt-6 text-center text-xs text-neutral-400 dark:border-neutral-800 dark:text-neutral-600"
    >
      Built with Astro · React · Tailwind · Framer Motion
    </footer>
  </main>
</Layout>
