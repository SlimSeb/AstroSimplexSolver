---
import { getMessages, localeMeta, localePath, locales, type Locale } from "../i18n";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = getMessages(lang);
---

<nav
  aria-label={t.langSwitcher.aria}
  class="inline-flex overflow-hidden rounded-md border border-neutral-300 text-xs font-semibold dark:border-neutral-700"
>
  {
    locales.map((loc) => {
      const active = loc === lang;
      return (
        <a
          href={localePath(loc)}
          hreflang={localeMeta[loc].htmlLang}
          aria-current={active ? "true" : undefined}
          class={`px-2.5 py-2 transition ${
            active
              ? "bg-neutral-900 text-white dark:bg-white dark:text-neutral-900"
              : "text-neutral-500 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:bg-neutral-900"
          }`}
        >
          {localeMeta[loc].short}
        </a>
      );
    })
  }
</nav>
